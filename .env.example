# CDK/deploy-time configuration. CDK context values override these env vars.
DEPLOY_ENV=dev
ALLOWED_ADMIN_GROUPS=collectool-dev-admin,collectool-dev-collectool-admins
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Repository allowed to assume the admin static deploy role.
ADMIN_GITHUB_REPOSITORY=castor-systems/collectool-admin
# Keep false for shared dev/prod. Use true only for local/manual sandbox testing.
SEED_INITIAL_DATA=false

# Local development only. These values are set automatically by npm local:* scripts.
DYNAMODB_ENDPOINT=http://localhost:8000
LOCAL_AWS_MOCKS=true
LOCAL_FAKE_AUTH=true
LOCAL_FAKE_ACCESS_TOKEN=mock-admin-access-token
LOCAL_FAKE_ADMIN_EMAIL=admin@collectool.local
LOCAL_FAKE_ADMIN_NAME=Mock Admin
LOCAL_API_PORT=3001
LOCAL_CORS_ORIGIN=http://localhost:3000
