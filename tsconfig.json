{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "include": [
    "bin/**/*.ts",
    "lib/**/*.ts",
    "src/**/*.ts",
    "test/**/*.js",
    "jest.config.js"
  ],
  "exclude": ["dist", "cdk.out", "node_modules"]
}
