{
  "name": "collectool-backend",
  "version": "0.1.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "bin": {
    "collectool-backend": "dist/bin/collectool-backend.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run openapi:lint && npm test && npm run security:iac",
    "audit:deps": "npm audit --audit-level=high",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "cdk": "cdk",
    "diff:dev": "cdk diff -c environment=dev",
    "diff:prod": "cdk diff -c environment=prod",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "github:configure-envs": "scripts/configure-github-environments.sh",
    "health": "scripts/health-check.sh",
    "lint": "eslint .",
    "local:api": "npm run build && node dist/src/local/server.js",
    "local:infra": "docker compose up -d dynamodb-local",
    "local:reset": "docker compose down -v",
    "local:seed": "npm run build && node dist/src/local/seed.js",
    "local:tables": "npm run build && node dist/src/local/create-tables.js",
    "local:up": "npm run local:infra && npm run local:tables && npm run local:seed && npm run local:api",
    "openapi:bundle": "redocly bundle docs/openapi.yaml --output /tmp/collectool-openapi.yaml",
    "openapi:lint": "redocly lint docs/openapi.yaml",
    "synth": "cdk synth",
    "synth:dev": "cdk synth -c environment=dev",
    "synth:prod": "cdk synth -c environment=prod",
    "deploy:dev": "cdk deploy -c environment=dev",
    "deploy:prod": "cdk deploy -c environment=prod",
    "outputs:dev": "scripts/stack-outputs.sh dev",
    "outputs:prod": "scripts/stack-outputs.sh prod",
    "security:iac": "cdk synth -c environment=dev -c securityChecks=true -c corsAllowedOrigins=http://localhost:3000 -c seedInitialData=false",
    "test": "npm run build && jest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@redocly/cli": "^2.18.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "ajv": "^8.20.0",
    "aws-cdk": "2.1119.0",
    "aws-sdk-client-mock": "^4.1.0",
    "cdk-nag": "^2.38.2",
    "conventional-changelog": "^7.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "^30",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1041.0",
    "@aws-sdk/client-dynamodb": "^3.1041.0",
    "@aws-sdk/lib-dynamodb": "^3.1041.0",
    "aws-cdk-lib": "^2.257.0",
    "constructs": "^10.6.0"
  }
}
